# backend/.dockerignore
# Excludes files that should NOT be copied into the Docker build context.
# Keep this list lean — only exclude what would pollute the image or expose secrets.

__pycache__
*.pyc
*.pyo
*.pyd
.env
.venv
venv
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
tests/
*.md
.git
.gitignore
